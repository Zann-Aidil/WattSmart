# Application
APP_NAME=SmartEnergy Predictor
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS - frontend origins (comma separated)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000,null

# Model
MODEL_PATH=ml/models/xgboost_model.pkl
SCALER_PATH=ml/models/scaler.pkl
FEATURE_NAMES_PATH=ml/models/feature_names.json

# Tariff (PLN R-1 1300 VA = Rp 1.444,70 per kWh)
TARIFF_PER_KWH=1444.70
CURRENCY_SYMBOL=Rp

# Logging
LOG_LEVEL=INFO
